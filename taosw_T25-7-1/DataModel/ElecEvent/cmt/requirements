package ElecEvent

use ROOT      v* Externals
use BaseEvent v* DataModel
use EDMUtil   v* DataModel

apply_pattern install_more_includes more=Event

macro ElecEvent_cintflags " -I$(ELECEVENTROOT) "
macro_append ElecEvent_cintflags " -I$(BASEEVENTROOT) "
macro_append ElecEvent_cintflags " -I$(EDMUTILROOT) "

macro_append ElecHeader_cintflags " $(ElecEvent_cintflags) "

apply_pattern cint_dictionary files="../Event/ElecHeader.h"
apply_pattern cint_dictionary files="../Event/ElecEvent.h"
apply_pattern cint_dictionary files="../Event/ElecChannel.h"


include_dirs $(ELECEVENTROOT)/
include_dirs $(ELECEVENTROOT)/Event
library ElecEvent *.cc
apply_pattern linker_library library=ElecEvent
